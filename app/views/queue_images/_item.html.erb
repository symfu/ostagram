<% debug = true %>
<% res_img = item_view_1.result_image %>

<li id="<%= item.id %>">


  <% if item.status > 1 %>
    <div class="row successMessage">
  <% else %>
    <div class="row">
  <% end %>


  <div class="col-md-1">
    <%= link_to(image_tag(item.content_image.thumb.url, alt: item.content_image, class: "productImage"), item.content_image.url, data: { lightbox: "content" }) %>
  </div>

  <div class="col-md-1">
    <%= link_to(image_tag(item.style_image.thumb.url, alt: item.style_image, class: "productImage"), item.style_image.url, data: { lightbox: "content" }) %>
  </div>


  <div class="col-md-1">
    <%= link_to(image_tag(res_img.imageurl.thumb.url, alt: res_img.imageurl, class: "productImage"), res_img.imageurl.url, data: { lightbox: "content" }) if res_img %>
  </div>

  <div class="col-md-3 hidden-phone">
    <% if false %>
      <span class="user">
       <%= link_to "share", item, method: :delete,
                   data: { confirm: "You sure?" } %>
      </span>
    <% end %>


    <span class="content"><p>Added: <%= (item.created_at + 10800).strftime("%d.%m.%Y %H:%M:%S") %></p> </span>


    <span class="timestamp">
        <% if item.status < 0 %>
            <p> Error during processing </p>
        <% elsif item.status == 0 %>
            <p> Waiting for processing </p>
        <% elsif item.status == 1 %>
            <p> Processed at (<%= item.pimages.count * 10 %>% </p>
        <% elsif item.status > 1 %>
            <p> Processed in <%= item.ptime.strftime("%H:%M:%S") if !item.ptime.nil? %> </p>
        <% end %>
      </span>

    <span class="user">
        <p> </p>
      <% if debug && item.status != 1 %>
        <%= link_to "delete", item, method: :delete, data: { confirm: "Are you sure you want to delete?" } %>
         <% end %>
      </span>

  </div>


  </div>

</li>